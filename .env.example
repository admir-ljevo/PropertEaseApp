# ── SQL Server ──────────────────────────────────────────────
SA_PASSWORD=your_strong_password_here

# ── JWT (min 32 chars) ───────────────────────────────────────
JWT_TOKEN_KEY=your-32-char-secret-key-here

# ── RabbitMQ ────────────────────────────────────────────────
